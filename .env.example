# 必填
SUBSCRIPTION_URL=https://example.com/api/v1/client/subscribe?token=change-me
KUMA_URL=http://uptime-kuma:3001
KUMA_USERNAME=admin
KUMA_PASSWORD=change-me

# 可选；留空时完全不管理 Status Page
KUMA_STATUS_PAGE_SLUG=
MONITOR_NAME_PREFIX=Proxy
KUMA_MONITOR_GROUP=Proxy Nodes

PROBE_INTERVAL=60
KUMA_HEARTBEAT_INTERVAL=75
SUBSCRIPTION_SYNC_INTERVAL=300
PROBE_TIMEOUT=10
PROBE_CONNECT_TIMEOUT=5
PROBE_CONCURRENCY=10
FAILURE_THRESHOLD=2
RECOVERY_THRESHOLD=1
TEST_URLS=https://cp.cloudflare.com/generate_204

XRAY_BINARY=/usr/local/bin/xray
XRAY_CONFIG=/app/generated/xray.json
SOCKS_PORT_START=20000
SOCKS_PORT_END=29999

REMOVED_NODE_POLICY=pause
REMOVED_NODE_GRACE_PERIOD=86400

LOG_LEVEL=INFO
TLS_VERIFY=true
DATABASE_PATH=/app/data/state.db
HEALTH_LISTEN=0.0.0.0
HEALTH_PORT=8080
KUMA_TIMEOUT=10
KUMA_RETRIES=3
